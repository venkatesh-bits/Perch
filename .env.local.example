# Copy this file to .env.local and fill in your Supabase project values.
# Get these from: https://supabase.com/dashboard -> your project -> Settings -> API
# The anon key is public by design (protected by Row Level Security). NEVER put
# the service_role key in any NEXT_PUBLIC_ variable or commit it.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL - used for canonical links, sitemap.xml, robots.txt and OG tags.
# Set this to your deployed origin in production (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Maps: none needed. Perch uses MapLibre GL JS + OpenFreeMap tiles -
# no API key, no billing account, no usage caps. Search runs client-side over a
# curated places list (lib/data/places.ts), so there is zero geocoding cost.
